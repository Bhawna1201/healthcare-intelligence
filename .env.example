# ─── healthcare_intelligence/.env ────────────────────────────────────────────
# Copy this to .env and fill in your values. NEVER commit .env to Git.

# ── Scraper behaviour ─────────────────────────────────────────────────────────
REQUEST_DELAY_MIN=2.0          # seconds between requests (min)
REQUEST_DELAY_MAX=4.0          # seconds between requests (max)
MAX_RETRIES=3
RETRY_WAIT_SECONDS=5

# ── ClinicalTrials.gov (free, no key needed) ──────────────────────────────────
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2/studies
CLINICALTRIALS_PAGE_SIZE=100

# ── OpenFDA (free, optional key for higher rate limits) ───────────────────────
# Get a free key at: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=
OPENFDA_BASE_URL=https://api.fda.gov

# ── NCBI / PubMed (free, optional key recommended) ───────────────────────────
# Get at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=your_email@example.com

# ── Scraping targets (adjust as needed) ───────────────────────────────────────
GOODRX_BASE_URL=https://www.goodrx.com
FDA_SHORTAGES_URL=https://www.accessdata.fda.gov/scripts/drugshortages
DRUGSCOM_BASE_URL=https://www.drugs.com

# ── Output paths ──────────────────────────────────────────────────────────────
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
MASTER_DATA_DIR=data/master
LOG_DIR=logs
